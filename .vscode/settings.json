{
  "git.path": "${workspaceFolder}/scripts/git.cmd",
  "git.autorefresh": false,
  "files.watcherExclude": {
    "**/.git/index": true,
    "**/.git/index.lock": true
  },
  "terminal.integrated.env.windows": {
    "PATH": "${workspaceFolder}\\scripts;${env:PATH}"
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell (StreamHub)": {
      "source": "PowerShell",
      "args": [
        "-NoLogo",
        "-Command",
        ". '${workspaceFolder}\\scripts\\git-terminal-init.ps1'"
      ]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell (StreamHub)"
}
